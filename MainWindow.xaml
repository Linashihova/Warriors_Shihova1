<Window x:Class="Warriors_Shihova.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Warriors_Shihova"
        mc:Ignorable="d"
        Title="Битва воинов" Height="450" Width="800" MinHeight="500" MinWidth="800">
    <Grid Background="#2D2D2D">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E1E1E" Padding="10">
            <TextBlock Text="Виртуальные методы. Битва воинов" 
                       Foreground="White" 
                       FontSize="20" 
                       HorizontalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#3D3D3D" Margin="5" CornerRadius="10" Padding="10">
                <StackPanel>
                    <TextBlock Text="Обычный воин" 
                               Foreground="White" 
                               FontSize="18" 
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>
                    <Canvas x:Name="WarriorCanvas" 
                            Width="200" 
                            Height="200" 
                            Background="#2A2A2A"
                            Margin="0,0,0,10"/>
                    <TextBlock x:Name="WarriorHealthText" 
                               Text="Жизни: 100" 
                               Foreground="White" 
                               FontSize="16" 
                               HorizontalAlignment="Center"
                               Margin="0,5"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#3D3D3D" Margin="5" CornerRadius="10" Padding="10">
                <StackPanel>
                    <TextBlock Text="Воин в легких доспехах" 
                               Foreground="White" 
                               FontSize="18" 
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>
                    <Canvas x:Name="LightWarriorCanvas" 
                            Width="200" 
                            Height="200" 
                            Background="#2A2A2A"
                            Margin="0,0,0,10"/>
                    <TextBlock x:Name="LightWarriorHealthText" 
                               Text="Жизни: 100" 
                               Foreground="White" 
                               FontSize="16" 
                               HorizontalAlignment="Center"
                               Margin="0,5"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#3D3D3D" Margin="5" CornerRadius="10" Padding="10">
                <StackPanel>
                    <TextBlock Text="Воин в тяжелых доспехах" 
                               Foreground="White" 
                               FontSize="18" 
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>
                    <Canvas x:Name="HeavyWarriorCanvas" 
                            Width="200" 
                            Height="200" 
                            Background="#2A2A2A"
                            Margin="0,0,0,10"/>
                    <TextBlock x:Name="HeavyWarriorHealthText" 
                               Text="Жизни: 100" 
                               Foreground="White" 
                               FontSize="16" 
                               HorizontalAlignment="Center"
                               Margin="0,5"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#1E1E1E" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Урон:" 
                           Foreground="White" 
                           FontSize="16" 
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <TextBox x:Name="DamageInput" 
                         Grid.Column="1"
                         Text="15" 
                         FontSize="16" 
                         Padding="5"
                         VerticalAlignment="Center"/>

                <Button x:Name="ApplyDamageToAllBtn" 
                        Grid.Column="2"
                        Content="Нанести урон всем" 
                        Padding="15,8"
                        Margin="10,0,0,0"
                        Click="ApplyDamageToAllBtn_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>